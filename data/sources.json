      "columns": ["nombre_del_municipio", "variable", "a_o", "promedio", "estaci_n", "tiempo_de_exposici_n_horas"],
      "filter": "nombre_del_municipio IN ('Medellín','MEDELLÍN','Medellin','MEDELLIN') AND variable='PM2.5' AND tiempo_de_exposici_n_horas='24'",
      "granularity": "per_station",
      "indicators": ["pm25-promedio"],
      "status": "active"
    },
    "ecv_medellin": {
