      "filter": "municipio='MEDELLIN'",
      "granularity": "municipal",
      "indicators": ["hurtos-personas", "tasa-hurtos"],
      "status": "active"
    },
    "violencia_intrafamiliar": {
      "platform": "datos_gov_co",
      "dataset_id": "ers2-kerr",
      "name": "Violencia intrafamiliar - Medicina Legal",
      "linea_tematica": "seguridad",
      "filter": "municipio_del_hecho like '%MEDELL%'",
      "granularity": "municipal",
