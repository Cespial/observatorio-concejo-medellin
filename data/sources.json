{
  "version": "1.0",
  "updated": "2026-02-16",
  "platforms": {
    "datos_gov_co": {
      "name": "datos.gov.co",
      "base_url": "https://www.datos.gov.co/resource",
      "api_type": "SOCRATA",
      "auth": {
        "token_env": "SOCRATA_APP_TOKEN",
        "required": false,
        "rate_limit_without": "1000/hr",
        "rate_limit_with": "50000/hr"
      }
    },
    "medata": {
      "name": "MEData - Datos Abiertos Medellin",
      "base_url": "https://medata.gov.co",
      "api_type": "CKAN",
      "auth": { "required": false }
    },
    "geomedellin": {
      "name": "GeoMedellin ArcGIS Hub",
      "base_url": "https://services1.arcgis.com/Qrk4Z5vQ94JXkdYM/arcgis/rest/services",
      "api_type": "ArcGIS_REST",
      "auth": { "required": false }
    },
    "metropol": {
      "name": "Area Metropolitana del Valle de Aburra",
      "base_url": "https://datosabiertos.metropol.gov.co",
      "api_type": "CKAN",
      "auth": { "required": false }
    }
  },
  "datasets": {
    "homicidios": {
      "platform": "datos_gov_co",
      "dataset_id": "m8fd-ahd9",
      "name": "HOMICIDIO - Policia Nacional",
      "linea_tematica": "seguridad",
      "filter": "municipio='MEDELLIN'",
      "select": "date_extract_y(fecha_hecho) as periodo, sum(cantidad) as total",
      "group_by": "periodo",
      "granularity": "municipal",
      "indicators": ["homicidios-absoluto", "tasa-homicidios"],
      "update_frequency": "continuous",
      "status": "active"
    },
    "hurtos_personas": {
      "platform": "datos_gov_co",
      "dataset_id": "4rxi-8m8d",
      "name": "HURTO PERSONAS - Policia Nacional",
