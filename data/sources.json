  },
  "env_vars": {
    "required": [
      { "name": "NEXT_PUBLIC_SUPABASE_URL", "description": "Supabase project URL" },
      { "name": "SUPABASE_SERVICE_ROLE_KEY", "description": "Supabase service role key for admin operations" },
      { "name": "NEXT_PUBLIC_SUPABASE_ANON_KEY", "description": "Supabase anonymous key for client-side reads" }
    ],
    "optional": [
      { "name": "SOCRATA_APP_TOKEN", "description": "datos.gov.co app token — increases rate limit from 1k/hr to 50k/hr" },
      { "name": "NEXT_PUBLIC_MAPBOX_TOKEN", "description": "Mapbox GL JS access token for map rendering" },
      { "name": "CLAUDE_API_KEY", "description": "Anthropic API key for chat assistant" }
    ]
  }
}
